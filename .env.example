# TaskForge local development example.
# Copy values into your local environment if needed, but never commit real secrets.

POSTGRES_DB=taskforge
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge_dev_password

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/taskforge
SPRING_DATASOURCE_USERNAME=taskforge
SPRING_DATASOURCE_PASSWORD=taskforge_dev_password
SERVER_PORT=8080
